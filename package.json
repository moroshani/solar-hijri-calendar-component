{
  "name": "solar-hijri-calendar-component",
  "version": "0.1.0",
  "description": "Reusable React Solar Hijri / Jalali calendar component.",
  "type": "module",
  "license": "MIT",
  "author": "Moroshani",
  "repository": {
    "type": "git",
    "url": "https://github.com/moroshani/solar-hijri-calendar-component.git"
  },
  "bugs": {
    "url": "https://github.com/moroshani/solar-hijri-calendar-component/issues"
  },
  "homepage": "https://github.com/moroshani/solar-hijri-calendar-component#readme",
  "keywords": [
    "react",
    "calendar",
    "jalali",
    "solar-hijri",
    "persian",
    "rtl",
    "datepicker"
  ],
  "sideEffects": [
    "dist/styles.css",
    "src/styles.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite --host 127.0.0.1",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jalaali-js": "^1.2.8"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
